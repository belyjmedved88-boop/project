<%- include('../partials/header') %>

<main class="section">
  <div class="container">
    <p class="eyebrow">Административный раздел</p>
    <h1>Заявки клиентов</h1>

    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <% if (requests.length === 0) { %>
      <p>Пока заявок нет.</p>
    <% } else { %>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>ФИО</th>
              <th>Компания</th>
              <th>Телефон</th>
              <th>E-mail</th>
              <th>Сообщение</th>
              <th>Статус</th>
              <th>Дата</th>
            </tr>
          </thead>
          <tbody>
            <% requests.forEach(function(item) { %>
              <tr>
                <td><%= item.id %></td>
                <td><%= item.full_name %></td>
                <td><%= item.company || '—' %></td>
                <td><%= item.phone %></td>
                <td><%= item.email %></td>
                <td><%= item.message %></td>
                <td><%= item.status %></td>
                <td><%= new Date(item.created_at).toLocaleString('ru-RU') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
